                <action android:name="android.service.wallpaper.WallpaperService" />
                <category android:name="com.google.android.wearable.watchface.category.WATCH_FACE" />
            </intent-filter>
            <meta-data android:name="android.service.wallpaper" android:resource="@xml/watch_face_void_mesh" />
            <meta-data android:name="com.google.android.wearable.watchface.preview" android:resource="@drawable/preview_void_mesh" />
        </service>

