        </service>

        <!-- たまペット (Tamagotchi Pet) Watch Face -->
        <service android:name=".TamagotchiWatchFaceService" android:exported="true" android:label="@string/tamagotchi_face_name" android:permission="android.permission.BIND_WALLPAPER">
