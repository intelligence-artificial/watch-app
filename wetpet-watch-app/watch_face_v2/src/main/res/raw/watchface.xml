<?xml version="1.0" encoding="UTF-8"?>
<!--
    WetPet V2 Watch Face — Pet Monitor Edition
    384×384 Pixel Watch 2

    Simplified: pet sprite as hero + analog arc clock on outer ring.
    Tap pet to open WetPet app for health data.
    No text, no complications, no digital clock.

    Analog clock reading:
      - Hour:    Bright dot on outer ring at current hour angle
      - Minute:  Sweep arc from 12 o'clock to current minute
      - Seconds: Orbiting dot with comet tail

    Design layers (back to front):
      1. Background fill with outer contour rings
      2. Hour indicator dot on outer ring
      3. Minute sweep arc on outer ring
      4. Seconds dot orbiter with comet tail
      5. 12 hour tick marks
      6. Pet glow ring (glassmorphism)
      7. Pet sprite (center, large)
      8. Full-pet tap → WetPet app
-->
<WatchFace width="384" height="384">

    <Metadata key="CLOCK_TYPE" value="ANALOG"/>
    <Metadata key="PREVIEW_TIME" value="10:08:32"/>

    <Scene backgroundColor="#ff050508">

        <!-- ════════════════════════════════════════════ -->
        <!--  BACKGROUND CONTOUR + OUTER TRACK           -->
        <!-- ════════════════════════════════════════════ -->
        <PartDraw x="0" y="0" width="384" height="384">
            <!-- Outer contour stroke -->
            <Ellipse x="2" y="2" width="380" height="380">
                <Stroke thickness="2" color="#20ffffff"/>
            </Ellipse>
            <!-- Inner shadow ring -->
            <Ellipse x="14" y="14" width="356" height="356">
                <Stroke thickness="1" color="#10ffffff"/>
            </Ellipse>
        </PartDraw>

        <!-- ════════════════════════════════════════════ -->
        <!--  HOUR INDICATOR DOT                         -->
        <!--  Bright dot on the outer ring at the        -->
        <!--  current hour angle. Uses smooth sub-hour   -->
        <!--  positioning: hour * 30 + minute * 0.5      -->
        <!-- ════════════════════════════════════════════ -->

        <!-- Track ring (dim, always visible) -->
        <PartDraw x="0" y="0" width="384" height="384">
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="0" endAngle="360" thickness="8">
                <Stroke color="#0Cffffff"/>
            </Arc>
        </PartDraw>

        <!-- Hour dot (interactive only) -->
        <PartDraw x="0" y="0" width="384" height="384">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-90 + [HOUR_0_11] * 30 + [MINUTE] * 0.5 - 5"
                 endAngle="-90 + [HOUR_0_11] * 30 + [MINUTE] * 0.5 + 5"
                 thickness="14">
                <Stroke color="#FFffffff" cap="ROUND"/>
            </Arc>
        </PartDraw>

        <!-- ════════════════════════════════════════════ -->
        <!--  MINUTE SWEEP ARC                           -->
        <!-- ════════════════════════════════════════════ -->

        <!-- Minute fill (interactive only) -->
        <PartDraw x="0" y="0" width="384" height="384">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-90"
                 endAngle="-90 + [MINUTE] * 6"
                 thickness="8">
                <Stroke color="#BB00D68F" cap="ROUND"/>
            </Arc>
        </PartDraw>

        <!-- ════════════════════════════════════════════ -->
        <!--  SECONDS ORBITER                            -->
        <!-- ════════════════════════════════════════════ -->
        <PartDraw x="0" y="0" width="384" height="384">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <!-- Comet tail -->
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-90 + [SECOND] * 6 - 36"
                 endAngle="-90 + [SECOND] * 6"
                 thickness="8">
                <Stroke color="#3300FFCC" cap="ROUND"/>
            </Arc>
            <!-- Bright head dot -->
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-90 + [SECOND] * 6 - 3"
                 endAngle="-90 + [SECOND] * 6 + 3"
                 thickness="10">
                <Stroke color="#FF00FFCC" cap="ROUND"/>
            </Arc>
        </PartDraw>

        <!-- ════════════════════════════════════════════ -->
        <!--  12 HOUR TICK MARKS                         -->
        <!-- ════════════════════════════════════════════ -->
        <PartDraw x="0" y="0" width="384" height="384">
            <!-- 12 o'clock -->
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-92.0" endAngle="-88.0" thickness="12">
                <Stroke color="#DD00FFCC" cap="ROUND"/>
            </Arc>
            <!-- 3 o'clock -->
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-1.0" endAngle="1.0" thickness="10">
                <Stroke color="#8800D68F" cap="ROUND"/>
            </Arc>
            <!-- 6 o'clock -->
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="89.0" endAngle="91.0" thickness="10">
                <Stroke color="#8800D68F" cap="ROUND"/>
            </Arc>
            <!-- 9 o'clock -->
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="179.0" endAngle="181.0" thickness="10">
                <Stroke color="#8800D68F" cap="ROUND"/>
            </Arc>
            <!-- 5-minute marks -->
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-61.0" endAngle="-59.0" thickness="8">
                <Stroke color="#5500D68F" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-31.0" endAngle="-29.0" thickness="8">
                <Stroke color="#5500D68F" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="29.0" endAngle="31.0" thickness="8">
                <Stroke color="#5500D68F" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="59.0" endAngle="61.0" thickness="8">
                <Stroke color="#5500D68F" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="119.0" endAngle="121.0" thickness="8">
                <Stroke color="#5500D68F" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="149.0" endAngle="151.0" thickness="8">
                <Stroke color="#5500D68F" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="209.0" endAngle="211.0" thickness="8">
                <Stroke color="#5500D68F" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="239.0" endAngle="241.0" thickness="8">
                <Stroke color="#5500D68F" cap="ROUND"/>
            </Arc>
        </PartDraw>

        <!-- Ambient: thin minute indicator + hour dot -->
        <PartDraw x="0" y="0" width="384" height="384">
            <Variant mode="INTERACTIVE" target="alpha" value="0"/>
            <Variant mode="AMBIENT" target="alpha" value="80"/>
            <!-- Thin minute arc -->
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-90"
                 endAngle="-90 + [MINUTE] * 6"
                 thickness="2">
                <Stroke color="#77AAAAAA" cap="ROUND"/>
            </Arc>
            <!-- Hour dot (dimmed) -->
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-90 + [HOUR_0_11] * 30 + [MINUTE] * 0.5 - 4"
                 endAngle="-90 + [HOUR_0_11] * 30 + [MINUTE] * 0.5 + 4"
                 thickness="10">
                <Stroke color="#99AAAAAA" cap="ROUND"/>
            </Arc>
        </PartDraw>

        <!-- ════════════════════════════════════════════ -->
        <!--  PET SPRITE (center, large hero)            -->
        <!-- ════════════════════════════════════════════ -->

        <!-- Soft glow ring (glassmorphism) -->
        <PartImage x="62" y="62" width="260" height="260">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <Image resource="glow_ring_pet"/>
        </PartImage>

        <ComplicationSlot
            x="82" y="82" width="220" height="220"
            slotId="0"
            displayName="Pet"
            isConfigurable="false"
            supportedTypes="SMALL_IMAGE"
            primaryDataSource="com.wetpet.watch/com.tamagotchi.pet.PetComplicationService"
            primaryDataSourceDefaultType="SMALL_IMAGE">
            <BoundingOval x="0" y="0" width="220" height="220" outlinePadding="2"/>
            <DefaultProviderPolicy
                primarySource="com.wetpet.watch/com.tamagotchi.pet.PetComplicationService"
                primarySourceDefaultType="SMALL_IMAGE"
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="SMALL_IMAGE"/>
            <Complication type="SMALL_IMAGE">
                <PartImage x="0" y="0" width="220" height="220">
                    <Variant mode="AMBIENT" target="alpha" value="0"/>
                    <Image resource="[COMPLICATION.SMALL_IMAGE]"/>
                </PartImage>
            </Complication>
        </ComplicationSlot>

        <PartImage x="122" y="122" width="140" height="140"
            alpha="0">
            <Variant mode="AMBIENT" target="alpha" value="60"/>
            <Image resource="dog_idle_aod"/>
        </PartImage>

        <!-- Tap pet → opens WetPet app -->
        <Group x="62" y="62" width="260" height="260">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <Launch target="com.wetpet.watch/com.tamagotchi.pet.HomeLaunchActivity"/>
        </Group>

        </Scene>

</WatchFace>
