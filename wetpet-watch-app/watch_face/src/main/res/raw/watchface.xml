<?xml version="1.0" encoding="UTF-8"?>
<!--
    WetPet Watch Face — Glassmorphism Edition
    384×384 Pixel Watch 2

    ═══════════════════════════════════════════
    COMPLICATION MAP (4 slots + battery)
    ═══════════════════════════════════════════

    SLOT 0 — "WetPet Pet"
      Position: Center (x=152 y=56, 80×80)
      Service:  PetComplicationService (SMALL_IMAGE)
      Tap:      HomeLaunchActivity trampoline → home screen

    SLOT 1 — "Heart Rate BPM"
      Position: Top-left (x=42 y=46, 90×90)
      Service:  HeartRateComplicationService (SHORT_TEXT)
      Tap:      Launch → hr_chart (default) or tapAction → hr_chart
      Fallback: Static ".. BPM" with red ring (shows when unbound)

    SLOT 2 — "Steps"
      Position: Top-right (x=252 y=46, 90×90)
      Service:  StepsComplicationService (SHORT_TEXT)
      Tap:      Launch → hr_chart (default) or tapAction → stats
      Fallback: Static ".. STEPS" with cyan ring (shows when unbound)

    BATTERY — Static WFF (no ComplicationSlot)
      Position: Bottom-center (x=132 y=265, 120×30)
      Uses:     [BATTERY_PERCENT] expression

    ═══════════════════════════════════════════

    Design layers (back to front):
      1. Background fill with outer contour ring
      2. Minute sweep arc on outer ring
      3. Seconds dot orbiter with comet tail
      4. Hour tick marks (12 positions)
      5. SLOT 1: Heart Rate BPM (top left)
      6. Battery pill (glassmorphism, bottom center)
      7. SLOT 0: Pet sprite (center) + Launch tap overlay
      8. Digital clock (large)
      9. Date pill
-->
<WatchFace width="384" height="384">

    <Metadata key="CLOCK_TYPE" value="DIGITAL"/>
    <Metadata key="PREVIEW_TIME" value="10:08:32"/>

    <Scene backgroundColor="#ff050508">

        <!-- ════════════════════════════════════════════ -->
        <!--  BACKGROUND CONTOUR + OUTER TRACK           -->
        <!-- ════════════════════════════════════════════ -->
        <PartDraw x="0" y="0" width="384" height="384">
            <!-- Outer contour stroke -->
            <Ellipse x="2" y="2" width="380" height="380">
                <Stroke thickness="2" color="#20ffffff"/>
            </Ellipse>
            <!-- Inner shadow ring -->
            <Ellipse x="14" y="14" width="356" height="356">
                <Stroke thickness="1" color="#10ffffff"/>
            </Ellipse>
        </PartDraw>

        <!-- ════════════════════════════════════════════ -->
        <!--  MINUTE SWEEP ARC                           -->
        <!-- ════════════════════════════════════════════ -->

        <!-- Track ring (dim, always visible) -->
        <PartDraw x="0" y="0" width="384" height="384">
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="0" endAngle="360" thickness="8">
                <Stroke color="#0Cffffff"/>
            </Arc>
        </PartDraw>

        <!-- Minute fill (interactive only) -->
        <PartDraw x="0" y="0" width="384" height="384">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-90"
                 endAngle="-90 + [MINUTE] * 6"
                 thickness="8">
                <Stroke color="#BB00D68F" cap="ROUND"/>
            </Arc>
        </PartDraw>

        <!-- ════════════════════════════════════════════ -->
        <!--  SECONDS ORBITER                            -->
        <!-- ════════════════════════════════════════════ -->
        <PartDraw x="0" y="0" width="384" height="384">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <!-- Comet tail -->
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-90 + [SECOND] * 6 - 36"
                 endAngle="-90 + [SECOND] * 6"
                 thickness="8">
                <Stroke color="#3300FFCC" cap="ROUND"/>
            </Arc>
            <!-- Bright head dot -->
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-90 + [SECOND] * 6 - 3"
                 endAngle="-90 + [SECOND] * 6 + 3"
                 thickness="10">
                <Stroke color="#FF00FFCC" cap="ROUND"/>
            </Arc>
        </PartDraw>

        <!-- ════════════════════════════════════════════ -->
        <!--  12 HOUR TICK MARKS (simplified)            -->
        <!-- ════════════════════════════════════════════ -->
        <PartDraw x="0" y="0" width="384" height="384">
            <!-- 12 o'clock -->
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-92.0" endAngle="-88.0" thickness="12">
                <Stroke color="#DD00FFCC" cap="ROUND"/>
            </Arc>
            <!-- 3 o'clock -->
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-1.0" endAngle="1.0" thickness="10">
                <Stroke color="#8800D68F" cap="ROUND"/>
            </Arc>
            <!-- 6 o'clock -->
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="89.0" endAngle="91.0" thickness="10">
                <Stroke color="#8800D68F" cap="ROUND"/>
            </Arc>
            <!-- 9 o'clock -->
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="179.0" endAngle="181.0" thickness="10">
                <Stroke color="#8800D68F" cap="ROUND"/>
            </Arc>
            <!-- 5-minute marks -->
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-61.0" endAngle="-59.0" thickness="8">
                <Stroke color="#5500D68F" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-31.0" endAngle="-29.0" thickness="8">
                <Stroke color="#5500D68F" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="29.0" endAngle="31.0" thickness="8">
                <Stroke color="#5500D68F" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="59.0" endAngle="61.0" thickness="8">
                <Stroke color="#5500D68F" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="119.0" endAngle="121.0" thickness="8">
                <Stroke color="#5500D68F" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="149.0" endAngle="151.0" thickness="8">
                <Stroke color="#5500D68F" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="209.0" endAngle="211.0" thickness="8">
                <Stroke color="#5500D68F" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="239.0" endAngle="241.0" thickness="8">
                <Stroke color="#5500D68F" cap="ROUND"/>
            </Arc>
        </PartDraw>

        <!-- Ambient: thin minute indicator -->
        <PartDraw x="0" y="0" width="384" height="384">
            <Variant mode="INTERACTIVE" target="alpha" value="0"/>
            <Variant mode="AMBIENT" target="alpha" value="80"/>
            <Arc centerX="192" centerY="192" width="372" height="372"
                 startAngle="-90"
                 endAngle="-90 + [MINUTE] * 6"
                 thickness="2">
                <Stroke color="#77AAAAAA" cap="ROUND"/>
            </Arc>
        </PartDraw>

        <!-- ════════════════════════════════════════════ -->
        <!--  HEART RATE (top left)                       -->
        <!--  Layer 1: Static fallback (always visible)   -->
        <!--  Layer 2: ComplicationSlot (shows BPM number)-->
        <!-- ════════════════════════════════════════════ -->

        <!-- Layer 1: Static fallback — always renders -->
        <Group x="42" y="46" width="90" height="90">
            <!-- Heart outline ring -->
            <PartDraw x="3" y="3" width="84" height="84">
                <Arc centerX="42" centerY="42" width="84" height="84"
                     startAngle="0" endAngle="360" thickness="7">
                    <Stroke color="#55FF3366" cap="ROUND"/>
                </Arc>
            </PartDraw>
            <!-- Dash placeholder -->
            <PartText x="5" y="14" width="80" height="34">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="22" color="#BBffffff" weight="BOLD">
                        <Template>--</Template>
                    </Font>
                </Text>
            </PartText>
            <!-- BPM label -->
            <PartText x="5" y="50" width="80" height="16">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="11" color="#88FF3366" weight="BOLD">
                        <Template>BPM</Template>
                    </Font>
                </Text>
            </PartText>
            <Variant mode="AMBIENT" target="alpha" value="0"/>
        </Group>

        <!-- Layer 2: ComplicationSlot — shows actual BPM when bound -->
        <ComplicationSlot
            x="42" y="46" width="90" height="90"
            slotId="1"
            displayName="Heart Rate"
            isConfigurable="false"
            supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
            defaultDataSource="com.wetpet.watch/com.tamagotchi.pet.HeartRateComplicationService"
            defaultDataSourceType="SHORT_TEXT">
            <BoundingOval x="0" y="0" width="90" height="90" outlinePadding="2"/>
            <DefaultProviderPolicy
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="SHORT_TEXT"/>

            <Complication type="SHORT_TEXT">
                <!-- Black fill to cover fallback -->
                <PartDraw x="10" y="10" width="70" height="70">
                    <Arc centerX="35" centerY="35" width="70" height="70"
                         startAngle="0" endAngle="360" thickness="34">
                        <Stroke color="#FF000000" cap="BUTT"/>
                    </Arc>
                </PartDraw>
                <!-- Heart outline ring -->
                <PartDraw x="3" y="3" width="84" height="84">
                    <Arc centerX="42" centerY="42" width="84" height="84"
                         startAngle="0" endAngle="360" thickness="7">
                        <Stroke color="#55FF3366" cap="ROUND"/>
                    </Arc>
                </PartDraw>
                <!-- BPM number — white, big, readable -->
                <PartText x="5" y="14" width="80" height="34">
                    <Text align="CENTER" ellipsis="TRUE">
                        <Font family="SYNC_TO_DEVICE" size="26" color="#FFffffff" weight="BOLD">
                            <Template><![CDATA[%s]]>
                                <Parameter expression="[COMPLICATION.TEXT]"/>
                            </Template>
                        </Font>
                    </Text>
                </PartText>
                <!-- BPM label -->
                <PartText x="5" y="50" width="80" height="16">
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="11" color="#88FF3366" weight="BOLD">
                            <Template>BPM</Template>
                        </Font>
                    </Text>
                </PartText>
                <Variant mode="AMBIENT" target="alpha" value="0"/>
            </Complication>

            <Complication type="RANGED_VALUE">
                <!-- Black fill -->
                <PartDraw x="10" y="10" width="70" height="70">
                    <Arc centerX="35" centerY="35" width="70" height="70"
                         startAngle="0" endAngle="360" thickness="34">
                        <Stroke color="#FF000000" cap="BUTT"/>
                    </Arc>
                </PartDraw>
                <!-- Heart outline ring -->
                <PartDraw x="3" y="3" width="84" height="84">
                    <Arc centerX="42" centerY="42" width="84" height="84"
                         startAngle="0" endAngle="360" thickness="7">
                        <Stroke color="#55FF3366" cap="ROUND"/>
                    </Arc>
                </PartDraw>
                <!-- BPM number — white -->
                <PartText x="5" y="14" width="80" height="34">
                    <Text align="CENTER" ellipsis="TRUE">
                        <Font family="SYNC_TO_DEVICE" size="26" color="#FFffffff" weight="BOLD">
                            <Template><![CDATA[%s]]>
                                <Parameter expression="[COMPLICATION.TEXT]"/>
                            </Template>
                        </Font>
                    </Text>
                </PartText>
                <!-- BPM label -->
                <PartText x="5" y="50" width="80" height="16">
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="11" color="#88FF3366" weight="BOLD">
                            <Template>BPM</Template>
                        </Font>
                    </Text>
                </PartText>
                <Variant mode="AMBIENT" target="alpha" value="0"/>
            </Complication>

            <!-- EMPTY: transparent so static fallback shows through -->
            <Complication type="EMPTY"/>
        </ComplicationSlot>

        <!-- Layer 3: Tap overlay for HR area — HrChartLaunchActivity trampoline -->
        <Group x="42" y="46" width="90" height="90">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <Launch target="com.wetpet.watch/com.tamagotchi.pet.HrChartLaunchActivity"/>
        </Group>


        <!-- ════════════════════════════════════════════ -->
        <!--  STEPS (top right)                          -->
        <!--  Layer 1: Static fallback (always visible)  -->
        <!--  Layer 2: ComplicationSlot (shows steps)    -->
        <!--  Layer 3: Tap overlay                       -->
        <!-- ════════════════════════════════════════════ -->

        <!-- Layer 1: Static fallback — always renders -->
        <Group x="252" y="46" width="90" height="90">
            <!-- Steps outline ring (cyan) -->
            <PartDraw x="3" y="3" width="84" height="84">
                <Arc centerX="42" centerY="42" width="84" height="84"
                     startAngle="0" endAngle="360" thickness="7">
                    <Stroke color="#5500D68F" cap="ROUND"/>
                </Arc>
            </PartDraw>
            <!-- Dash placeholder -->
            <PartText x="5" y="14" width="80" height="34">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="22" color="#BBffffff" weight="BOLD">
                        <Template>--</Template>
                    </Font>
                </Text>
            </PartText>
            <!-- STEPS label -->
            <PartText x="5" y="50" width="80" height="16">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="11" color="#8800D68F" weight="BOLD">
                        <Template>STEPS</Template>
                    </Font>
                </Text>
            </PartText>
            <Variant mode="AMBIENT" target="alpha" value="0"/>
        </Group>

        <!-- Layer 2: ComplicationSlot — shows actual step count when bound -->
        <ComplicationSlot
            x="252" y="46" width="90" height="90"
            slotId="2"
            displayName="Steps"
            isConfigurable="false"
            supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
            defaultDataSource="com.wetpet.watch/com.tamagotchi.pet.StepsComplicationService"
            defaultDataSourceType="SHORT_TEXT">
            <BoundingOval x="0" y="0" width="90" height="90" outlinePadding="2"/>
            <DefaultProviderPolicy
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="SHORT_TEXT"/>
            <Complication type="SHORT_TEXT">
                <!-- Steps outline ring (cyan, brighter when bound) -->
                <PartDraw x="3" y="3" width="84" height="84">
                    <Arc centerX="42" centerY="42" width="84" height="84"
                         startAngle="0" endAngle="360" thickness="7">
                        <Stroke color="#AA00D68F" cap="ROUND"/>
                    </Arc>
                </PartDraw>
                <!-- Step count number -->
                <PartText x="5" y="14" width="80" height="34">
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="20" color="#FFffffff" weight="BOLD">
                            <Template>[COMPLICATION.SHORT_TEXT]</Template>
                        </Font>
                    </Text>
                </PartText>
                <!-- STEPS label -->
                <PartText x="5" y="50" width="80" height="16">
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="11" color="#8800D68F" weight="BOLD">
                            <Template>STEPS</Template>
                        </Font>
                    </Text>
                </PartText>
                <Variant mode="AMBIENT" target="alpha" value="0"/>
            </Complication>

            <!-- EMPTY: transparent so static fallback shows through -->
            <Complication type="EMPTY"/>
        </ComplicationSlot>

        <!-- Layer 3: Tap overlay for Steps area — StatsLaunchActivity trampoline -->
        <Group x="252" y="46" width="90" height="90">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <Launch target="com.wetpet.watch/com.tamagotchi.pet.StatsLaunchActivity"/>
        </Group>


        <!-- ════════════════════════════════════════════ -->
        <!--  CALORIES (bottom left)                     -->
        <!--  Layer 1: Static fallback (always visible)  -->
        <!--  Layer 2: ComplicationSlot (shows calories)  -->
        <!--  Layer 3: Tap overlay                       -->
        <!-- ════════════════════════════════════════════ -->

        <!-- Layer 1: Static fallback -->
        <Group x="42" y="200" width="90" height="90">
            <PartDraw x="3" y="3" width="84" height="84">
                <Arc centerX="42" centerY="42" width="84" height="84"
                     startAngle="0" endAngle="360" thickness="7">
                    <Stroke color="#55FF6B35" cap="ROUND"/>
                </Arc>
            </PartDraw>
            <PartText x="5" y="14" width="80" height="34">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="22" color="#BBffffff" weight="BOLD">
                        <Template>--</Template>
                    </Font>
                </Text>
            </PartText>
            <PartText x="5" y="50" width="80" height="16">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="11" color="#88FF6B35" weight="BOLD">
                        <Template>KCAL</Template>
                    </Font>
                </Text>
            </PartText>
            <Variant mode="AMBIENT" target="alpha" value="0"/>
        </Group>

        <!-- Layer 2: ComplicationSlot -->
        <ComplicationSlot
            x="42" y="200" width="90" height="90"
            slotId="3"
            displayName="Calories"
            isConfigurable="false"
            supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
            defaultDataSource="com.wetpet.watch/com.tamagotchi.pet.CaloriesComplicationService"
            defaultDataSourceType="SHORT_TEXT">
            <BoundingOval x="0" y="0" width="90" height="90" outlinePadding="2"/>
            <DefaultProviderPolicy
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="SHORT_TEXT"/>
            <Complication type="SHORT_TEXT">
                <PartDraw x="3" y="3" width="84" height="84">
                    <Arc centerX="42" centerY="42" width="84" height="84"
                         startAngle="0" endAngle="360" thickness="7">
                        <Stroke color="#AAFF6B35" cap="ROUND"/>
                    </Arc>
                </PartDraw>
                <PartText x="5" y="14" width="80" height="34">
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="20" color="#FFffffff" weight="BOLD">
                            <Template>[COMPLICATION.SHORT_TEXT]</Template>
                        </Font>
                    </Text>
                </PartText>
                <PartText x="5" y="50" width="80" height="16">
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="11" color="#88FF6B35" weight="BOLD">
                            <Template>KCAL</Template>
                        </Font>
                    </Text>
                </PartText>
                <Variant mode="AMBIENT" target="alpha" value="0"/>
            </Complication>
            <Complication type="EMPTY"/>
        </ComplicationSlot>

        <!-- Layer 3: Tap overlay — CaloriesLaunchActivity trampoline -->
        <Group x="42" y="200" width="90" height="90">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <Launch target="com.wetpet.watch/com.tamagotchi.pet.CaloriesLaunchActivity"/>
        </Group>

        <!-- ════════════════════════════════════════════ -->
        <!--  BATTERY (bottom center)                   -->
        <!--  Glassmorphism pill + horizontal fill       -->
        <!-- ════════════════════════════════════════════ -->
        <Group x="132" y="265" width="120" height="30">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <PartImage x="0" y="0" width="120" height="30">
                <Image resource="glass_pill_battery"/>
            </PartImage>
            <!-- Battery fill bar track -->
            <PartDraw x="12" y="11" width="96" height="8">
                <RoundRectangle x="0" y="0" width="96" height="8"
                                cornerRadiusX="4" cornerRadiusY="4">
                    <Fill color="#1850FF78"/>
                </RoundRectangle>
            </PartDraw>
            <!-- Battery fill bar (scaled) -->
            <PartDraw x="12" y="11" width="96" height="8">
                <RoundRectangle x="0" y="0" width="96" height="8"
                                cornerRadiusX="4" cornerRadiusY="4">
                    <Fill color="#CC50FF78"/>
                    <Transform target="width" value="clamp([BATTERY_PERCENT], 0, 100) * 0.96"/>
                </RoundRectangle>
            </PartDraw>
            <!-- Value + icon -->
            <PartText x="4" y="6" width="112" height="18">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="11" color="#DD50FF78" weight="BOLD">
                        <Template>⚡ %d%%
                            <Parameter expression="[BATTERY_PERCENT]"/>
                        </Template>
                    </Font>
                </Text>
            </PartText>
        </Group>

        <!-- ════════════════════════════════════════════ -->
        <!--  PET SPRITE                                 -->
        <!-- ════════════════════════════════════════════ -->

        <!-- Soft glow ring (glassmorphism) -->
        <PartImage x="137" y="41" width="110" height="110">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <Image resource="glow_ring_pet"/>
        </PartImage>

        <!-- Pet sprite via ComplicationSlot -->
        <ComplicationSlot
            x="152" y="56" width="80" height="80"
            slotId="0"
            displayName="Pet"
            isConfigurable="false"
            supportedTypes="SMALL_IMAGE EMPTY"
            defaultDataSource="com.wetpet.watch/com.tamagotchi.pet.PetComplicationService"
            defaultDataSourceType="SMALL_IMAGE">
            <BoundingOval x="0" y="0" width="80" height="80" outlinePadding="2"/>
            <DefaultProviderPolicy
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="SMALL_IMAGE"/>
            <Complication type="SMALL_IMAGE">
                <PartImage x="0" y="0" width="80" height="80">
                    <Variant mode="AMBIENT" target="alpha" value="0"/>
                    <Image resource="[COMPLICATION.SMALL_IMAGE]"/>
                </PartImage>
            </Complication>
            <Complication type="EMPTY">
                <PartImage x="0" y="0" width="80" height="80">
                    <Variant mode="AMBIENT" target="alpha" value="0"/>
                    <Image resource="pet_idle_1_green"/>
                </PartImage>
            </Complication>
        </ComplicationSlot>

        <!-- AOD pet (static, dimmed) -->
        <PartImage x="152" y="56" width="80" height="80">
            <Variant mode="AMBIENT" target="alpha" value="60"/>
            <Variant mode="INTERACTIVE" target="alpha" value="0"/>
            <Image resource="pet_idle_aod"/>
        </PartImage>



        <!-- SLOT 0 TAP: Pet complication tap — opens WetPet home -->
        <!-- Uses HomeLaunchActivity trampoline to route to home screen -->
        <Group x="137" y="41" width="110" height="110">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <Launch target="com.wetpet.watch/com.tamagotchi.pet.HomeLaunchActivity"/>
        </Group>

        <!--  DIGITAL CLOCK                              -->
        <!-- ════════════════════════════════════════════ -->
        <DigitalClock x="0" y="0" width="384" height="384">
            <!-- Interactive: white, bold -->
            <TimeText format="h:mm" hourFormat="SYNC_TO_DEVICE"
                      align="CENTER"
                      x="0" y="162" width="384" height="60"
                      alpha="255">
                <Variant mode="AMBIENT" target="alpha" value="0"/>
                <Font family="SYNC_TO_DEVICE" size="52" weight="BOLD"
                      color="#ffffffff"/>
            </TimeText>
            <!-- Ambient: gray, thin -->
            <TimeText format="h:mm" hourFormat="SYNC_TO_DEVICE"
                      align="CENTER"
                      x="0" y="162" width="384" height="60"
                      alpha="0">
                <Variant mode="AMBIENT" target="alpha" value="180"/>
                <Font family="SYNC_TO_DEVICE" size="52" weight="THIN"
                      color="#ffCCCCCC"/>
            </TimeText>
        </DigitalClock>

        <!-- ════════════════════════════════════════════ -->
        <!--  DATE (glassmorphism pill)                  -->
        <!-- ════════════════════════════════════════════ -->
        <Group x="132" y="224" width="120" height="22">
            <PartDraw x="0" y="0" width="120" height="22">
                <RoundRectangle x="0" y="0" width="120" height="22"
                                cornerRadiusX="11" cornerRadiusY="11">
                    <Fill color="#ff101018"/>
                </RoundRectangle>
            </PartDraw>
            <PartText x="4" y="3" width="112" height="16">
                <Text align="CENTER">
                    <Font family="SYNC_TO_DEVICE" size="11" color="#88ffffff">
                        <Template>%s  %d/%d
                            <Parameter expression="[DAY_OF_WEEK_S]"/>
                            <Parameter expression="[MONTH_0_11] + 1"/>
                            <Parameter expression="[DAY_OF_MONTH] + 1"/>
                        </Template>
                    </Font>
