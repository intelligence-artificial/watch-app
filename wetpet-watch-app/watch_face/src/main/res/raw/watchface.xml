<?xml version="1.0" encoding="UTF-8"?>
<!--
    WetPet Watch Face — v6 (tight radial layout)
    Display: 384×384 circular AMOLED (Pixel Watch 2)

    Layout from center outward:
      1. Pet sprite (center, 80×80)
      2. Emotion text (just below pet)
      3. Time (large, below emotion)
      4. Date + wellness (compact bottom zone)
      5. Data arcs: steps (top), battery (right), HR (left)
      6. Complication values inside arcs
      7. Thin bezel ring
-->
<WatchFace width="384" height="384">

    <Metadata key="CLOCK_TYPE" value="DIGITAL"/>
    <Metadata key="PREVIEW_TIME" value="10:08:32"/>

    <Scene backgroundColor="#ff000000">

        <!-- ═══════════════════════════════════════ -->
        <!--  THIN OUTER BEZEL                      -->
        <!-- ═══════════════════════════════════════ -->
        <PartDraw x="0" y="0" width="384" height="384">
            <Arc centerX="192" centerY="192" width="380" height="380"
                 startAngle="0" endAngle="360" thickness="3">
                <Stroke color="#ff0D0D18"/>
            </Arc>
            <!-- 12 o'clock accent -->
            <Arc centerX="192" centerY="192" width="380" height="380"
                 startAngle="-92" endAngle="-88" thickness="3">
                <Stroke color="#ff00E5FF"/>
            </Arc>
        </PartDraw>

        <!-- ═══════════════════════════════════════ -->
        <!--  STEPS ARC — top (10→2 o'clock, 120°)  -->
        <!--  Cyan, outermost data ring              -->
        <!-- ═══════════════════════════════════════ -->
        <PartDraw x="0" y="0" width="384" height="384">
            <Variant mode="AMBIENT" target="alpha" value="35"/>
            <Arc centerX="192" centerY="192" width="362" height="362"
                 startAngle="-150" endAngle="-30" thickness="10">
                <Stroke color="#1500E5FF" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="362" height="362"
                 startAngle="-150" endAngle="-30" thickness="10">
                <Stroke color="#9900E5FF" cap="ROUND"/>
            </Arc>
        </PartDraw>

        <!-- ═══════════════════════════════════════ -->
        <!--  BATTERY ARC — right (2→5, 90°)        -->
        <!--  Green                                  -->
        <!-- ═══════════════════════════════════════ -->
        <PartDraw x="0" y="0" width="384" height="384">
            <Arc centerX="192" centerY="192" width="362" height="362"
                 startAngle="-25" endAngle="60" thickness="10">
                <Stroke color="#1550FF78" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="362" height="362"
                 startAngle="-25"
                 endAngle="-25 + clamp([BATTERY_PERCENT], 0, 100) * 0.85"
                 thickness="10">
                <Stroke color="#9950FF78" cap="ROUND"/>
            </Arc>
        </PartDraw>

        <!-- ═══════════════════════════════════════ -->
        <!--  HR ARC — left (7→10, 90°)             -->
        <!--  Pink                                   -->
        <!-- ═══════════════════════════════════════ -->
        <PartDraw x="0" y="0" width="384" height="384">
            <Variant mode="AMBIENT" target="alpha" value="35"/>
            <Arc centerX="192" centerY="192" width="362" height="362"
                 startAngle="120" endAngle="210" thickness="10">
                <Stroke color="#15FF5580" cap="ROUND"/>
            </Arc>
            <Arc centerX="192" centerY="192" width="362" height="362"
                 startAngle="120" endAngle="210" thickness="10">
                <Stroke color="#99FF5580" cap="ROUND"/>
            </Arc>
        </PartDraw>

        <!-- ═══════════════════════════════════════ -->
        <!--  BOTTOM ARC — ambient zone (5→7, 60°)  -->
        <!-- ═══════════════════════════════════════ -->
        <PartDraw x="0" y="0" width="384" height="384">
            <Arc centerX="192" centerY="192" width="362" height="362"
                 startAngle="65" endAngle="115" thickness="10">
                <Stroke color="#0800E5FF" cap="ROUND"/>
            </Arc>
        </PartDraw>

        <!-- ═══════════════════════════════════════ -->
        <!--  DATA VALUES (inside each arc zone)    -->
        <!-- ═══════════════════════════════════════ -->

        <!-- Steps (top center, inside cyan arc) -->
        <ComplicationSlot
            x="142" y="14" width="100" height="18"
            slotId="1"
            displayName="Steps"
            supportedTypes="SHORT_TEXT EMPTY">
            <DefaultProviderPolicy
                defaultSystemProvider="STEP_COUNT"
                defaultSystemProviderType="SHORT_TEXT"/>
            <Complication type="SHORT_TEXT">
                <ShortText x="0" y="0" width="100" height="18">
                    <Variant mode="AMBIENT" target="alpha" value="0"/>
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="11" color="#BB00E5FF" weight="BOLD"/>
                    </Text>
                </ShortText>
            </Complication>
            <Complication type="EMPTY">
                <PartText x="0" y="0" width="100" height="18">
                    <Variant mode="AMBIENT" target="alpha" value="0"/>
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="10" color="#4000E5FF">
                            <Template>0</Template>
                        </Font>
                    </Text>
                </PartText>
            </Complication>
        </ComplicationSlot>

        <!-- Battery % (right side, inside green arc) -->
        <PartText x="310" y="170" width="56" height="18">
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="11" color="#BB50FF78" weight="BOLD">
                    <Template>%d%%
                        <Parameter expression="[BATTERY_PERCENT]"/>
                    </Template>
                </Font>
            </Text>
            <Variant mode="AMBIENT" target="alpha" value="50"/>
        </PartText>

        <!-- HR (left side, inside pink arc) -->
        <ComplicationSlot
            x="18" y="170" width="56" height="18"
            slotId="2"
            displayName="Heart Rate"
            supportedTypes="SHORT_TEXT EMPTY">
            <DefaultProviderPolicy
                defaultSystemProvider="HEART_RATE"
                defaultSystemProviderType="SHORT_TEXT"/>
            <Complication type="SHORT_TEXT">
                <ShortText x="0" y="0" width="56" height="18">
                    <Variant mode="AMBIENT" target="alpha" value="0"/>
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="11" color="#BBFF5580" weight="BOLD"/>
                    </Text>
                </ShortText>
            </Complication>
            <Complication type="EMPTY">
                <PartText x="0" y="0" width="56" height="18">
                    <Variant mode="AMBIENT" target="alpha" value="0"/>
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="10" color="#40FF5580">
                            <Template>♥</Template>
                        </Font>
                    </Text>
                </PartText>
            </Complication>
        </ComplicationSlot>

        <!-- Seconds dot -->
        <PartDraw x="0" y="0" width="384" height="384">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <Arc centerX="192" centerY="192" width="362" height="362"
                 startAngle="-90 + [SECOND] * 6 - 1"
                 endAngle="-90 + [SECOND] * 6 + 1"
                 thickness="4">
                <Stroke color="#ff00E5FF" cap="ROUND"/>
            </Arc>
        </PartDraw>

        <!-- ═══════════════════════════════════════ -->
        <!--  INNER GLOW RING (decorative)          -->
        <!-- ═══════════════════════════════════════ -->
        <PartDraw x="0" y="0" width="384" height="384">
            <Arc centerX="192" centerY="192" width="280" height="280"
                 startAngle="0" endAngle="360" thickness="1">
                <Stroke color="#08ffffff"/>
            </Arc>
        </PartDraw>

        <!-- ═══════════════════════════════════════ -->
        <!--  PET SPRITE — hero center               -->
        <!--  Direct PartImage (no complication)      -->
        <!-- ═══════════════════════════════════════ -->

        <!-- Interactive: dog sprite -->
        <PartImage x="152" y="72" width="80" height="80">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <Image resource="dog_idle_1_green"/>
        </PartImage>

        <!-- AOD pet (dimmed grayscale) -->
        <PartImage x="152" y="72" width="80" height="80">
            <Variant mode="AMBIENT" target="alpha" value="100"/>
            <Variant mode="INTERACTIVE" target="alpha" value="0"/>
            <Image resource="dog_idle_aod"/>
        </PartImage>

        <!-- App launch tap zone (overlapping pet) -->
        <Group x="152" y="72" width="80" height="80">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <Launch target="com.wetpet.watch"/>
        </Group>

        <!-- ═══════════════════════════════════════ -->
        <!--  EMOTION TEXT (just below pet)           -->
        <!-- ═══════════════════════════════════════ -->
        <ComplicationSlot
            x="67" y="155" width="250" height="20"
            slotId="3"
            displayName="mood"
            isConfigurable="false"
            supportedTypes="SHORT_TEXT EMPTY"
            defaultDataSource="com.wetpet.watch/com.tamagotchi.pet.EmotionComplicationService"
            defaultDataSourceType="SHORT_TEXT">
            <DefaultProviderPolicy
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="SHORT_TEXT"/>
            <Complication type="SHORT_TEXT">
                <ShortText x="0" y="0" width="250" height="20">
                    <Variant mode="AMBIENT" target="alpha" value="0"/>
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="12" color="#CC78FFA0" weight="BOLD"/>
                    </Text>
                </ShortText>
            </Complication>
            <Complication type="EMPTY">
                <PartText x="0" y="0" width="250" height="20">
                    <Variant mode="AMBIENT" target="alpha" value="0"/>
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="10" color="#4478FFA0">
                            <Template>· · ·</Template>
                        </Font>
                    </Text>
                </PartText>
            </Complication>
        </ComplicationSlot>

        <!-- ═══════════════════════════════════════ -->
        <!--  DIGITAL CLOCK (primary, large)         -->
        <!-- ═══════════════════════════════════════ -->
        <DigitalClock x="0" y="0" width="384" height="384">
            <TimeText format="h:mm" hourFormat="SYNC_TO_DEVICE"
                      align="CENTER"
                      x="0" y="178" width="384" height="55"
                      alpha="255">
                <Variant mode="AMBIENT" target="alpha" value="0"/>
                <Font family="SYNC_TO_DEVICE" size="48" weight="BOLD"
                      color="#ff00E5FF"/>
            </TimeText>
            <TimeText format="h:mm" hourFormat="SYNC_TO_DEVICE"
                      align="CENTER"
                      x="0" y="178" width="384" height="55"
                      alpha="0">
                <Variant mode="AMBIENT" target="alpha" value="255"/>
                <Font family="SYNC_TO_DEVICE" size="48" weight="THIN"
                      color="#ffBBBBBB"/>
            </TimeText>
        </DigitalClock>

        <!-- ═══════════════════════════════════════ -->
        <!--  DATE (compact, below time)             -->
        <!-- ═══════════════════════════════════════ -->
        <PartText x="0" y="236" width="384" height="16">
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="11" color="#ff3A3A48">
                    <Template>%s  %d/%d
                        <Parameter expression="[DAY_OF_WEEK_S]"/>
                        <Parameter expression="[MONTH_0_11] + 1"/>
                        <Parameter expression="[DAY_OF_MONTH] + 1"/>
                    </Template>
                </Font>
            </Text>
            <Variant mode="AMBIENT" target="alpha" value="70"/>
        </PartText>

        <!-- ═══════════════════════════════════════ -->
        <!--  WELLNESS NEEDS (below date)            -->
        <!-- ═══════════════════════════════════════ -->
        <ComplicationSlot
            x="102" y="256" width="180" height="18"
            slotId="4"
            displayName="wellness"
            isConfigurable="false"
            supportedTypes="SHORT_TEXT RANGED_VALUE EMPTY"
            defaultDataSource="com.wetpet.watch/com.tamagotchi.pet.NeedsComplicationService"
            defaultDataSourceType="SHORT_TEXT">
            <DefaultProviderPolicy
                defaultSystemProvider="EMPTY"
                defaultSystemProviderType="SHORT_TEXT"/>
            <Complication type="SHORT_TEXT">
                <ShortText x="0" y="0" width="180" height="18">
                    <Variant mode="AMBIENT" target="alpha" value="0"/>
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="10" color="#99FFE664" weight="BOLD"/>
                    </Text>
                </ShortText>
            </Complication>
            <Complication type="RANGED_VALUE">
                <ShortText x="0" y="0" width="180" height="18">
                    <Variant mode="AMBIENT" target="alpha" value="0"/>
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="10" color="#99FFE664" weight="BOLD"/>
                    </Text>
                </ShortText>
            </Complication>
            <Complication type="EMPTY">
                <PartText x="0" y="0" width="180" height="18">
                    <Variant mode="AMBIENT" target="alpha" value="0"/>
                    <Text align="CENTER">
                        <Font family="SYNC_TO_DEVICE" size="9" color="#33FFE664">
                            <Template>· · ·</Template>
                        </Font>
                    </Text>
                </PartText>
            </Complication>
        </ComplicationSlot>

        <!-- Branding (very subtle, bottom) -->
        <PartText x="0" y="280" width="384" height="14">
            <Variant mode="AMBIENT" target="alpha" value="0"/>
            <Text align="CENTER">
                <Font family="SYNC_TO_DEVICE" size="7" color="#ff151520">
                    <Template>W E T P E T</Template>
                </Font>
            </Text>
        </PartText>

    </Scene>
</WatchFace>
