<?xml version="1.0" encoding="utf-8"?>
<!-- WetPet — Scuba Dive Computer Watch Face (WFF v2) -->
<WatchFace width="450" height="450">

    <UserConfigurations>
        <ListConfiguration id="PET_COLOR" displayName="Pet Color" defaultValue="green">
            <ListOption id="green" displayName="Neon Green" />
            <ListOption id="blue" displayName="Neon Blue" />
            <ListOption id="pink" displayName="Neon Pink" />
            <ListOption id="yellow" displayName="Neon Yellow" />
        </ListConfiguration>
    </UserConfigurations>

    <Scene backgroundColor="#020206">

        <!-- ══════════════════════════════════════════ -->
        <!--  OUTER RING: Steps / Daily Goal (270°)    -->
        <!-- ══════════════════════════════════════════ -->
        <PartDraw x="0" y="0" width="450" height="450">
            <Variant mode="ambient" target="alpha" value="0"/>
            <!-- Background track -->
            <Arc centerX="225" centerY="225" width="430" height="430"
                 startAngle="-225" endAngle="45" thickness="8">
                <Stroke color="#0A50E6FF"/>
            </Arc>
            <!-- Fill arc (steps / 10000 * 270°) -->
            <Arc centerX="225" centerY="225" width="430" height="430"
                 startAngle="-225" endAngle="-225 + (([STEP_COUNT] / 10000) * 270)" thickness="8"
                 direction="CLOCKWISE">
                <Stroke color="#50E6FF" cap="ROUND"/>
            </Arc>
            <!-- 25% tick mark -->
            <Arc centerX="225" centerY="225" width="430" height="430"
                 startAngle="-157.5" endAngle="-155.5" thickness="12">
                <Stroke color="#1AFFFFFF"/>
            </Arc>
            <!-- 50% tick mark -->
            <Arc centerX="225" centerY="225" width="430" height="430"
                 startAngle="-90" endAngle="-88" thickness="12">
                <Stroke color="#1AFFFFFF"/>
            </Arc>
            <!-- 75% tick mark -->
            <Arc centerX="225" centerY="225" width="430" height="430"
                 startAngle="-22.5" endAngle="-20.5" thickness="12">
                <Stroke color="#1AFFFFFF"/>
            </Arc>
        </PartDraw>

        <!-- ══════════════════════════════════════════ -->
        <!--  SECOND RING: Battery (top 90°)           -->
        <!-- ══════════════════════════════════════════ -->
        <PartDraw x="0" y="0" width="450" height="450">
            <Variant mode="ambient" target="alpha" value="80"/>
            <!-- Background track -->
            <Arc centerX="225" centerY="225" width="400" height="400"
                 startAngle="-135" endAngle="-45" thickness="6">
                <Stroke color="#0A50FF78"/>
            </Arc>
            <!-- Fill arc -->
            <Arc centerX="225" centerY="225" width="400" height="400"
                 startAngle="-135" endAngle="-135 + ([BATTERY_PERCENT] * 0.9)" thickness="6"
                 direction="CLOCKWISE">
                <Condition>
                    <Expression>[BATTERY_PERCENT] le 30</Expression>
                    <Stroke color="#FF4646" cap="ROUND"/>
                    <Default>
                        <Stroke color="#50FF78" cap="ROUND"/>
                    </Default>
                </Condition>
            </Arc>
        </PartDraw>

        <!-- ══════════════════════════════════════════ -->
        <!--  SECONDS RING (innermost, full 360°)      -->
        <!-- ══════════════════════════════════════════ -->
        <PartDraw x="0" y="0" width="450" height="450">
            <Variant mode="ambient" target="alpha" value="0"/>
            <Arc centerX="225" centerY="225" width="340" height="340"
                 startAngle="-90" endAngle="-90 + [SECOND] * 6" thickness="3">
                <Stroke color="#2050FF78"/>
            </Arc>
        </PartDraw>

        <!-- ══════════════════════════════════════════ -->
        <!--  BATTERY % label (top center)             -->
        <!-- ══════════════════════════════════════════ -->
        <PartText x="225" y="48" width="100" height="20">
            <Variant mode="ambient" target="alpha" value="100"/>
            <Text align="CENTER">
                <Font family="SYNC-TO-DEVICE" size="13" color="#50FF78" />
                <Variant mode="ambient" target="color" value="#555555" />
                <Template>⚡%d%%
                    <Parameter expression="[BATTERY_PERCENT]" />
                </Template>
            </Text>
        </PartText>

        <!-- ══════════════════════════════════════════ -->
        <!--  STEP COUNT label (bottom of outer ring)  -->
        <!-- ══════════════════════════════════════════ -->
        <PartText x="225" y="410" width="150" height="20">
            <Variant mode="ambient" target="alpha" value="0"/>
            <Text align="CENTER">
                <Font family="SYNC-TO-DEVICE" size="13" color="#50E6FF" />
                <Template>👟 %d steps
                    <Parameter expression="[STEP_COUNT]" />
                </Template>
            </Text>
        </PartText>

        <!-- ══════════════════════════════════════════ -->
        <!--  THE WETPET (CENTER HERO)                 -->
        <!--  Sprite switches based on steps + time    -->
        <!-- ══════════════════════════════════════════ -->

        <Condition>
            <!-- Night mode: Sleeping (22:00 - 05:00) -->
            <Expression>[HOUR_0_23] ge 22 or [HOUR_0_23] le 5</Expression>

            <PartImage x="153" y="140" width="144" height="144">
                <Variant mode="ambient" target="image" value="pet_sleep_aod" />
                <Image resource="pet_sleep_green" />
                <Variant configuration="PET_COLOR" optionId="blue" target="image" value="pet_sleep_blue" />
                <Variant configuration="PET_COLOR" optionId="pink" target="image" value="pet_sleep_pink" />
                <Variant configuration="PET_COLOR" optionId="yellow" target="image" value="pet_sleep_yellow" />
            </PartImage>
            <!-- Sleepy status text -->
            <PartText x="225" y="290" width="200" height="20">
                <Variant mode="ambient" target="alpha" value="0"/>
                <Text align="CENTER">
                    <Font family="SYNC-TO-DEVICE" size="14" color="#6060A0" />
                    <Template>sleepy time... Zzz</Template>
                </Text>
            </PartText>

            <Default>
                <!-- Daytime: check step count for mood -->
                <Condition>
                    <!-- HAPPY: steps > 8000 -->
                    <Expression>[STEP_COUNT] ge 8000</Expression>

                    <!-- Happy pet with bounce -->
                    <Group x="153" y="140" width="144" height="144">
                        <Variant mode="ambient" target="alpha" value="0" />
                        <Transform target="y" value="sin([SECOND] * 4) * 5" />
                        <Condition>
                            <Expression>([SECOND] % 2) eq 0</Expression>
                            <PartImage x="0" y="0" width="144" height="144">
                                <Image resource="pet_idle_1_green" />
                                <Variant configuration="PET_COLOR" optionId="blue" target="image" value="pet_idle_1_blue" />
                                <Variant configuration="PET_COLOR" optionId="pink" target="image" value="pet_idle_1_pink" />
                                <Variant configuration="PET_COLOR" optionId="yellow" target="image" value="pet_idle_1_yellow" />
                            </PartImage>
                            <Default>
                                <PartImage x="0" y="0" width="144" height="144">
                                    <Image resource="pet_idle_2_green" />
                                    <Variant configuration="PET_COLOR" optionId="blue" target="image" value="pet_idle_2_blue" />
                                    <Variant configuration="PET_COLOR" optionId="pink" target="image" value="pet_idle_2_pink" />
                                    <Variant configuration="PET_COLOR" optionId="yellow" target="image" value="pet_idle_2_yellow" />
                                </PartImage>
                            </Default>
                        </Condition>
                    </Group>
                    <!-- Happy status text -->
                    <PartText x="225" y="290" width="200" height="20">
                        <Variant mode="ambient" target="alpha" value="0"/>
                        <Text align="CENTER">
                            <Font family="SYNC-TO-DEVICE" size="14" color="#50E6FF" />
                            <Template>great day! ♥</Template>
                        </Text>
                    </PartText>

                    <Default>
                        <Condition>
                            <!-- SAD: steps < 1000 after 6pm -->
                            <Expression>[STEP_COUNT] lt 1000 and [HOUR_0_23] ge 18</Expression>

                            <!-- Sad pet (slow bounce) -->
                            <Group x="153" y="140" width="144" height="144">
                                <Variant mode="ambient" target="alpha" value="0" />
                                <Transform target="y" value="sin([SECOND]) * 1" />
                                <PartImage x="0" y="0" width="144" height="144">
                                    <Image resource="pet_sleep_green" />
                                    <Variant configuration="PET_COLOR" optionId="blue" target="image" value="pet_sleep_blue" />
                                    <Variant configuration="PET_COLOR" optionId="pink" target="image" value="pet_sleep_pink" />
                                    <Variant configuration="PET_COLOR" optionId="yellow" target="image" value="pet_sleep_yellow" />
                                </PartImage>
                            </Group>
                            <PartText x="225" y="290" width="200" height="20">
                                <Variant mode="ambient" target="alpha" value="0"/>
                                <Text align="CENTER">
                                    <Font family="SYNC-TO-DEVICE" size="14" color="#5070A0" />
                                    <Template>feeling down... move!</Template>
                                </Text>
                            </PartText>

                            <Default>
                                <!-- IDLE: normal animated pet -->
                                <Group x="153" y="140" width="144" height="144">
                                    <Variant mode="ambient" target="alpha" value="0" />
                                    <Transform target="y" value="sin([SECOND] * 3) * 3" />
                                    <Condition>
                                        <Expression>([SECOND] % 2) eq 0</Expression>
                                        <PartImage x="0" y="0" width="144" height="144">
                                            <Image resource="pet_idle_1_green" />
                                            <Variant configuration="PET_COLOR" optionId="blue" target="image" value="pet_idle_1_blue" />
                                            <Variant configuration="PET_COLOR" optionId="pink" target="image" value="pet_idle_1_pink" />
                                            <Variant configuration="PET_COLOR" optionId="yellow" target="image" value="pet_idle_1_yellow" />
                                        </PartImage>
                                        <Default>
                                            <PartImage x="0" y="0" width="144" height="144">
                                                <Image resource="pet_idle_2_green" />
                                                <Variant configuration="PET_COLOR" optionId="blue" target="image" value="pet_idle_2_blue" />
                                                <Variant configuration="PET_COLOR" optionId="pink" target="image" value="pet_idle_2_pink" />
                                                <Variant configuration="PET_COLOR" optionId="yellow" target="image" value="pet_idle_2_yellow" />
                                            </PartImage>
                                        </Default>
                                    </Condition>
                                </Group>
                                <!-- Idle status text -->
                                <PartText x="225" y="290" width="200" height="20">
                                    <Variant mode="ambient" target="alpha" value="0"/>
                                    <Text align="CENTER">
                                        <Font family="SYNC-TO-DEVICE" size="14" color="#78C890" />
                                        <Template>all good ♪</Template>
                                    </Text>
                                </PartText>

                                <!-- AOD: static outline -->
                                <PartImage x="153" y="140" width="144" height="144">
                                    <Variant mode="ambient" target="alpha" value="255" />
                                    <Variant mode="ambient" target="image" value="pet_idle_aod" />
                                    <Variant mode="interactive" target="alpha" value="0" />
                                    <Image resource="pet_idle_aod" />
                                </PartImage>
                            </Default>
                        </Condition>
                    </Default>
                </Condition>
            </Default>
        </Condition>

        <!-- ══════════════════════════════════════════ -->
        <!--  DIGITAL CLOCK (below pet)                -->
        <!-- ══════════════════════════════════════════ -->
        <!-- Glow layer -->
        <PartText x="225" y="330" width="200" height="55">
            <Variant mode="ambient" target="alpha" value="0"/>
            <Text align="CENTER">
                <Font family="SYNC-TO-DEVICE" size="44" color="#3050FF78" weight="BOLD" />
                <Template>%sh:%02d
                    <Parameter expression="[HOUR_1_12]" />
                    <Parameter expression="[MINUTE]" />
                </Template>
            </Text>
        </PartText>
        <!-- Main clock -->
        <PartText x="225" y="330" width="200" height="55">
            <Text align="CENTER">
                <Font family="SYNC-TO-DEVICE" size="44" color="#50FF78" weight="BOLD" />
                <Variant mode="ambient" target="color" value="#AAAAAA" />
                <Template>%sh:%02d
                    <Parameter expression="[HOUR_1_12]" />
                    <Parameter expression="[MINUTE]" />
                </Template>
            </Text>
        </PartText>

        <!-- ══════════════════════════════════════════ -->
        <!--  DATE (below clock)                       -->
        <!-- ══════════════════════════════════════════ -->
        <PartText x="225" y="370" width="200" height="25">
            <Text align="CENTER">
                <Font family="SYNC-TO-DEVICE" size="15" color="#888888" />
                <Variant mode="ambient" target="color" value="#555555" />
                <Template>%s %d/%d
                    <Parameter expression="[DAY_OF_WEEK_S]" />
                    <Parameter expression="[MONTH]" />
                    <Parameter expression="[DAY_OF_MONTH]" />
                </Template>
            </Text>
        </PartText>

    </Scene>
</WatchFace>
