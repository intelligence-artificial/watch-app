# ============================================
# watch-app — .gitignore
# ============================================

# Build outputs
*.apk
*.aab
*.dex
*.class
**/build/
.gradle/
.cxx/

# Local properties (contains SDK paths)
local.properties

# IDE
.idea/
*.iml
.vscode/

# Gradle wrapper JAR (downloaded at build time)
gradle/wrapper/gradle-wrapper.jar

# Recordings (sensitive voice data)
recordings/
*.m4a
*.wav
*.3gp

# ML Models (too large for git)
**/src/main/assets/model/
*.bin
*.ggml

# whisper.cpp source clone (legacy)
mobile/whisper.cpp/

# JNI / native build outputs
mobile/src/main/jni/
*.so
*.o

# OS files
Thumbs.db
.DS_Store
desktop.ini

# Logs & temp output
*.log
nohup.out

# Screenshots (debug artifacts)
*.png

# Temp/debug files
debug_phone.bat
debug_watch.bat

# Environment files
.env
.env.*

# Secrets
*.keystore
*.jks
*.pem
*.key

# Vosk temp extraction
vosk-extract/

# Antigravity outputs (agent temp files)
.antigravity-outputs/

# Python
venv/
__pycache__/

# Node (if any tooling)
node_modules/
